#include <stdio.h>

int main() {
    int n, i, j, isUnique;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter elements:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("\nUnique elements are:\n");

    for(i = 0; i < n; i++) {
        isUnique = 1;

        for(j = 0; j < i; j++) {
            if(arr[i] == arr[j]) {
                isUnique = 0;
                break;
            }
        }

        if(isUnique) {
            printf("%d ", arr[i]);
        }
    }

    return 0;
}